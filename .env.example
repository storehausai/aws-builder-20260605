# =============================================================================
#  aws-builder-20260605 — environment template
#  Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
#  To make these available to the Claude Code MCP servers in .mcp.json:
#     set -a; source .env; set +a; claude
# =============================================================================

# --- RocketRide (AI pipeline engine) ----------------------------------------
# Where: rocketride.org dashboard → API Keys.  OR run the engine locally via
# Docker (no cloud key needed): listens on :5565.
ROCKETRIDE_APIKEY=
# Engine endpoint. Local Docker engine = http://localhost:5565 ; cloud = https://api.rocketride.ai
ROCKETRIDE_URI=http://localhost:5565
# Lets RocketRide pipelines call Butterbase nodes (reuse the bb_sk_ service key):
ROCKETRIDE_BUTTERBASE_KEY=bb_sk_

# --- Internal service wiring (pipelines/engine/web call each other) ----------
ENGINE_URL=http://localhost:8787
ENGINE_PORT=8787
WEB_URL=http://localhost:3000
# Optional AI-gateway model overrides (defaults are sensible):
# BB_MODEL=anthropic/claude-sonnet-4.6
# BB_FAST_MODEL=google/gemini-2.5-flash

# --- Butterbase (DB + auth + storage + AI gateway) --------------------------
# Where: dashboard.butterbase.ai → create app → Settings.
# Redeem hackathon promo HAVEFUN0605 in Billing first.
NEXT_PUBLIC_BUTTERBASE_APP_ID=app_
NEXT_PUBLIC_BUTTERBASE_API_URL=https://api.butterbase.ai
# Server-side service key (bb_sk_...). Also used as the Bearer token for the
# Butterbase MCP server. KEEP SECRET — never expose to the browser.
BUTTERBASE_SERVICE_KEY=bb_sk_

# --- XTrace (persistent memory) ---------------------------------------------
# Where: xtrace.ai → sign in → Settings / API Keys (key prefix xtk_).
XTRACE_API_KEY=xtk_
XTRACE_ORG_ID=

# --- Photon / Spectrum (messaging delivery: iMessage/WhatsApp/etc.) ---------
# Where: photon.codes → Spectrum Cloud dashboard → Project credentials.
# (Photon has no MCP server — wired in app code via the spectrum-ts SDK.)
# Leave PROJECT_ID/SECRET blank to fall back to the projectless `terminal`
# provider for local dev. For real iMessage, set these (Spectrum Cloud number)
# OR run imessage-kit locally on this Mac (Full Disk Access + Messages signed in).
PROJECT_ID=
PROJECT_SECRET=
# The marketer's iMessage handle/phone that influencer replies get relayed to.
MARKETER_IMESSAGE=

# --- Instagram DM — UNOFFICIAL cold-send path (the chosen demo path) ---------
# Sends the FIRST/cold DM to any influencer by @handle (the official Meta API
# cannot — it only replies after the user messages first). Uses a dedicated
# BURNER brand account; ToS/ban risk → pre-warm it + persist the session.
#   1) fill IG_USERNAME/IG_PASSWORD  2) run `pnpm ig:login` once (persists session)
#   3) the agent sends via @pebble/outreach; replies polled + relayed to iMessage.
IG_BACKEND=private
IG_USERNAME=
IG_PASSWORD=
IG_SESSION_PATH=.ig-session.json
IG_PROXY=
IG_POLL_MS=15000

# --- Instagram DM — OFFICIAL Meta Graph API path (compliant fallback) --------
# Reply-only (within 24h after the user DMs first). Set IG_BACKEND=graph to use.
# Official "Instagram API with Instagram Login" (recommended). In DEVELOPMENT
# mode you can exchange DMs with accounts that hold a role (developer/tester) on
# the app without App Review. Inbound arrives via the webhook below; you reply
# within the 24h window to the IGSID from that inbound event.
#   Where: developers.facebook.com → your app → Instagram → API setup with
#          Instagram login → generate an IG user access token.
IG_ACCESS_TOKEN=
# API base + send path. Defaults shown (IG-login flow). For the Facebook-Page-
# linked flow use base=https://graph.facebook.com/v21.0 and sendPath=<PAGE_ID>/messages
IG_GRAPH_BASE=https://graph.instagram.com/v21.0
IG_SEND_PATH=me/messages
# A token YOU invent; paste the same value into the Meta app Webhooks config.
IG_WEBHOOK_VERIFY_TOKEN=
# Local webhook receiver (expose via ngrok; register https://.../webhook in Meta).
PORT=8080
OUTREACH_STORE=.outreach/inbound.json

# --- Data providers ---------------------------------------------------------
# Fill in KEEPA_API_KEY + SCRAPECREATORS_API_KEY with your provider keys.
# APIFY_TOKEN — get one at apify.com → Settings → API.
KEEPA_API_KEY=
APIFY_TOKEN=
SCRAPECREATORS_API_KEY=

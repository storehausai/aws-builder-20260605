{ "pipeline": { "source": "chat_1", "components": [
  { "id": "chat_1", "provider": "chat", "config": { "mode": "Source" } },
  { "id": "agent", "provider": "agent_rocketride", "config": { "max_waves": 3, "instructions": ["You are a test agent. Reply with exactly: ROCKETRIDE_OK"] }, "input": [{ "lane": "questions", "from": "chat_1" }] },
  { "id": "llm", "provider": "llm_openai", "config": { "baseURL": "https://api.butterbase.ai/v1", "model": "anthropic/claude-sonnet-4.6", "apikey": "${ROCKETRIDE_BUTTERBASE_KEY}" }, "control": [{ "classType": "llm", "from": "agent" }] },
  { "id": "mem", "provider": "memory_internal", "config": {}, "control": [{ "classType": "memory", "from": "agent" }] },
  { "id": "out", "provider": "response_answers", "config": { "laneName": "answers" }, "input": [{ "lane": "answers", "from": "agent" }] }
] } }
